# ============================================================================
# Canvastack Controller Configuration - Environment Variables
# ============================================================================
# بِسْمِ ٱللَّٰهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ
#
# This file contains all available environment variables for the Canvastack
# Controller configuration. Copy the variables you need to your .env file.
#
# All values shown are the defaults. You only need to add variables to .env
# if you want to override the defaults.
# ============================================================================

# ----------------------------------------------------------------------------
# Security Configuration
# ----------------------------------------------------------------------------

# XSS Protection - Escape all user-controllable output
CANVASTACK_CONTROLLER_XSS_PROTECTION=true

# CSRF Protection - Require valid CSRF tokens for POST requests
CANVASTACK_CONTROLLER_CSRF_PROTECTION=true

# SQL Injection Prevention - Use parameterized queries
CANVASTACK_CONTROLLER_SQL_INJECTION_PREVENTION=true

# Escape Output - Escape all output by default
CANVASTACK_CONTROLLER_ESCAPE_OUTPUT=true

# Max File Size - Maximum upload size in bytes (default: 10MB)
CANVASTACK_CONTROLLER_MAX_FILE_SIZE=10485760

# Sanitize Filenames - Remove dangerous characters from filenames
CANVASTACK_CONTROLLER_SANITIZE_FILENAMES=true

# Scan Malicious Content - Basic malware scanning for uploads
CANVASTACK_CONTROLLER_SCAN_MALICIOUS_CONTENT=true

# Session Timeout - Session timeout in seconds (default: 2 hours)
CANVASTACK_CONTROLLER_SESSION_TIMEOUT=7200

# Regenerate Session ID - Regenerate after authentication
CANVASTACK_CONTROLLER_REGENERATE_SESSION_ID=true

# ----------------------------------------------------------------------------
# Performance Configuration
# ----------------------------------------------------------------------------

# Enable Caching - Master switch for all caching features
CANVASTACK_CONTROLLER_ENABLE_CACHING=true

# Cache TTL - Default cache time-to-live in seconds (default: 1 hour)
CANVASTACK_CONTROLLER_CACHE_TTL=3600

# Eager Loading - Prevent N+1 query problems
CANVASTACK_CONTROLLER_EAGER_LOADING=true

# Query Optimization - Optimize database queries
CANVASTACK_CONTROLLER_QUERY_OPTIMIZATION=true

# Memory Limit - PHP memory limit for controller operations
CANVASTACK_CONTROLLER_MEMORY_LIMIT=256M

# Query Monitoring - Log slow queries
CANVASTACK_CONTROLLER_QUERY_MONITORING=true

# Slow Query Threshold - Threshold in milliseconds (default: 1 second)
CANVASTACK_CONTROLLER_SLOW_QUERY_THRESHOLD=1000

# Batch Insert Chunk Size - Records per batch (default: 100)
CANVASTACK_CONTROLLER_BATCH_INSERT_CHUNK_SIZE=100

# Helper Optimization - Optimize helper functions
CANVASTACK_CONTROLLER_ENABLE_HELPER_OPTIMIZATION=true

# Helper Cache TTL - Helper function cache TTL in seconds (default: 1 hour)
CANVASTACK_CONTROLLER_HELPER_CACHE_TTL=3600

# String Operation Optimization - Optimize string operations
CANVASTACK_CONTROLLER_OPTIMIZE_STRING_OPERATIONS=true

# ----------------------------------------------------------------------------
# Caching Configuration (Specific Components)
# ----------------------------------------------------------------------------

# Privilege Cache - Cache user privilege checks
CANVASTACK_CONTROLLER_PRIVILEGE_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_PRIVILEGE_CACHE_TTL=3600

# Route Info Cache - Cache route information
CANVASTACK_CONTROLLER_ROUTE_INFO_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_ROUTE_INFO_CACHE_TTL=3600

# Preference Cache - Cache user preferences
CANVASTACK_CONTROLLER_PREFERENCE_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_PREFERENCE_CACHE_TTL=7200

# View Cache - Cache compiled views
CANVASTACK_CONTROLLER_VIEW_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_VIEW_CACHE_TTL=3600

# File Validation Cache - Cache file validation results
CANVASTACK_CONTROLLER_FILE_VALIDATION_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_FILE_VALIDATION_CACHE_TTL=7200

# ----------------------------------------------------------------------------
# File Upload Configuration
# ----------------------------------------------------------------------------

# Chunked Upload - Enable chunking for large files
CANVASTACK_CONTROLLER_ENABLE_CHUNKING=true
CANVASTACK_CONTROLLER_CHUNK_SIZE=1048576

# Thumbnails - Auto-generate thumbnails for images
CANVASTACK_CONTROLLER_ENABLE_THUMBNAILS=true
CANVASTACK_CONTROLLER_THUMBNAIL_WIDTH=150
CANVASTACK_CONTROLLER_THUMBNAIL_HEIGHT=150

# Storage Path - Base path for uploads (relative to storage)
CANVASTACK_CONTROLLER_STORAGE_PATH=uploads

# Unique Filenames - Generate unique names to prevent overwrites
CANVASTACK_CONTROLLER_GENERATE_UNIQUE_FILENAMES=true

# Image Quality - Quality for image processing (1-100)
CANVASTACK_CONTROLLER_IMAGE_QUALITY=85

# Max Image Dimensions - Maximum width/height (null = no limit)
CANVASTACK_CONTROLLER_MAX_IMAGE_WIDTH=
CANVASTACK_CONTROLLER_MAX_IMAGE_HEIGHT=

# Upload Limits
CANVASTACK_CONTROLLER_MAX_CONCURRENT_UPLOADS=5
CANVASTACK_CONTROLLER_MAX_UPLOAD_TIME=300

# Upload Progress Tracking
CANVASTACK_CONTROLLER_UPLOAD_PROGRESS_TRACKING=true
CANVASTACK_CONTROLLER_UPLOAD_PROGRESS_INTERVAL=5

# ----------------------------------------------------------------------------
# Validation Configuration
# ----------------------------------------------------------------------------

# Strict Mode - Enable additional validation checks
CANVASTACK_CONTROLLER_STRICT_MODE=true

# Table/Column Validation - Validate against schema
CANVASTACK_CONTROLLER_VALIDATE_TABLE_NAMES=true
CANVASTACK_CONTROLLER_VALIDATE_COLUMN_NAMES=true

# Max Query Length - Maximum SQL query length in characters
CANVASTACK_CONTROLLER_MAX_QUERY_LENGTH=10000

# MIME Type Validation - Validate file MIME types
CANVASTACK_CONTROLLER_VALIDATE_MIME_TYPES=true

# Image Dimension Validation - Validate image dimensions
CANVASTACK_CONTROLLER_VALIDATE_IMAGE_DIMENSIONS=true

# Array Depth - Maximum nesting depth for arrays
CANVASTACK_CONTROLLER_MAX_ARRAY_DEPTH=10

# Max Input Variables - Maximum input variables per request
CANVASTACK_CONTROLLER_MAX_INPUT_VARIABLES=1000

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------

# Log Security Events - Log XSS, SQL injection attempts, etc.
CANVASTACK_CONTROLLER_LOG_SECURITY_EVENTS=true

# Log Performance Issues - Log slow queries, high memory usage
CANVASTACK_CONTROLLER_LOG_PERFORMANCE_ISSUES=true

# Log Validation Failures - Log validation errors
CANVASTACK_CONTROLLER_LOG_VALIDATION_FAILURES=true

# Log File Uploads - Log upload activities
CANVASTACK_CONTROLLER_LOG_FILE_UPLOADS=true

# Log Privilege Violations - Log unauthorized access attempts
CANVASTACK_CONTROLLER_LOG_PRIVILEGE_VIOLATIONS=true

# Log DataTables Requests - Log DataTables AJAX requests (verbose)
CANVASTACK_CONTROLLER_LOG_DATATABLES_REQUESTS=false

# Log Database Queries - Log all queries (very verbose)
CANVASTACK_CONTROLLER_LOG_DATABASE_QUERIES=false

# Log Channel - Laravel log channel (null = default)
CANVASTACK_CONTROLLER_LOG_CHANNEL=

# Log Level - Minimum log level (emergency, alert, critical, error, warning, notice, info, debug)
CANVASTACK_CONTROLLER_LOG_LEVEL=info

# ----------------------------------------------------------------------------
# DataTables Configuration
# ----------------------------------------------------------------------------

# POST Method - Use POST for DataTables server-side processing
CANVASTACK_CONTROLLER_DATATABLES_POST=true

# Max Records Per Page - Maximum records per page
CANVASTACK_CONTROLLER_DATATABLES_MAX_RECORDS=1000

# Default Page Length - Default records per page
CANVASTACK_CONTROLLER_DATATABLES_PAGE_LENGTH=10

# Enable Search - Enable global search
CANVASTACK_CONTROLLER_DATATABLES_SEARCH=true

# Enable Ordering - Enable column ordering
CANVASTACK_CONTROLLER_DATATABLES_ORDERING=true

# ----------------------------------------------------------------------------
# Session Configuration
# ----------------------------------------------------------------------------

# Session Integrity - Validate session data integrity
CANVASTACK_CONTROLLER_SESSION_VALIDATE_INTEGRITY=true

# Encrypt Sensitive Data - Encrypt sensitive session data
CANVASTACK_CONTROLLER_SESSION_ENCRYPT_SENSITIVE=true

# Session Data Version - Version for session data structure
CANVASTACK_CONTROLLER_SESSION_DATA_VERSION=1

# ----------------------------------------------------------------------------
# Error Handling & Graceful Degradation
# ----------------------------------------------------------------------------

# Graceful Degradation - Handle errors gracefully with fallbacks
CANVASTACK_CONTROLLER_GRACEFUL_DEGRADATION=true

# Database Error Handling - Handle database errors gracefully
CANVASTACK_CONTROLLER_HANDLE_DB_ERRORS=true

# File System Error Handling - Handle filesystem errors
CANVASTACK_CONTROLLER_HANDLE_FS_ERRORS=true

# Cache Error Handling - Fallback to database on cache errors
CANVASTACK_CONTROLLER_HANDLE_CACHE_ERRORS=true

# Session Error Handling - Redirect to login on session errors
CANVASTACK_CONTROLLER_HANDLE_SESSION_ERRORS=true

# User-Friendly Messages - Replace technical errors with friendly messages
CANVASTACK_CONTROLLER_USER_FRIENDLY_MESSAGES=true

# Log Detailed Errors - Log detailed error information
CANVASTACK_CONTROLLER_LOG_DETAILED_ERRORS=true

# Prevent Silent Failures - Never ignore errors silently
CANVASTACK_CONTROLLER_PREVENT_SILENT_FAILURES=true

# Retry Mechanisms - Retry transient errors automatically
CANVASTACK_CONTROLLER_ENABLE_RETRY=true
CANVASTACK_CONTROLLER_MAX_RETRY_ATTEMPTS=3
CANVASTACK_CONTROLLER_RETRY_DELAY_MS=100

# Cache Fallback - Fallback to database when cache fails
CANVASTACK_CONTROLLER_CACHE_FALLBACK_DB=true

# Session Error Redirect - Route to redirect on session errors
CANVASTACK_CONTROLLER_SESSION_ERROR_ROUTE=login

# Display Error Details - Show details in development mode
CANVASTACK_CONTROLLER_DISPLAY_ERROR_DETAILS=true

# Modal Alert for Errors - Show errors in modal dialog
CANVASTACK_CONTROLLER_SHOW_MODAL_ALERT=true
CANVASTACK_CONTROLLER_MODAL_ALERT_TITLE="File Upload Error"
CANVASTACK_CONTROLLER_MODAL_ALERT_BUTTON=Close

# ----------------------------------------------------------------------------
# Script Management Configuration
# ----------------------------------------------------------------------------

# Script Minification - Minify JavaScript and CSS
CANVASTACK_CONTROLLER_ENABLE_MINIFICATION=false
CANVASTACK_CONTROLLER_MINIFY_INLINE_SCRIPTS=false
CANVASTACK_CONTROLLER_MINIFY_EXTERNAL_SCRIPTS=false

# Minification Cache
CANVASTACK_CONTROLLER_MINIFICATION_CACHE_ENABLED=true
CANVASTACK_CONTROLLER_MINIFICATION_CACHE_TTL=86400

# Preserve Important Comments - Keep copyright notices
CANVASTACK_CONTROLLER_PRESERVE_IMPORTANT_COMMENTS=true

# Script Concatenation - Combine inline scripts
CANVASTACK_CONTROLLER_ENABLE_CONCATENATION=false

# Minification Error Handling
CANVASTACK_CONTROLLER_HANDLE_MINIFICATION_ERRORS=true
CANVASTACK_CONTROLLER_LOG_MINIFICATION_ERRORS=true

# Script Manifests - Cache script metadata
CANVASTACK_CONTROLLER_CACHE_MANIFESTS=true
CANVASTACK_CONTROLLER_MANIFEST_CACHE_TTL=3600

# Missing Script Handling - Handle missing scripts gracefully
CANVASTACK_CONTROLLER_HANDLE_MISSING_SCRIPTS=true
CANVASTACK_CONTROLLER_SHOW_MISSING_WARNINGS=true
CANVASTACK_CONTROLLER_LOG_MISSING_SCRIPTS=true
CANVASTACK_CONTROLLER_CACHE_EXISTENCE_CHECKS=true

# ============================================================================
# End of Canvastack Controller Configuration
# ============================================================================
