# CanvaStack Package Environment Example
# Copy this to your Laravel application's .env file

APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:ptHzab8jC2cd0sZoWS1/MnSlJsN4fSh4xrZiLcvqFHc=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

XDEBUG_MODE=coverage

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# Mantra ETL Database (for TanStack Tabs Demo)
# DB_HOST_MANTRA_ETL=127.0.0.1
# DB_PORT_MANTRA_ETL=3306
# DB_DATABASE_MANTRA_ETL=mantra_etl
# DB_USERNAME_MANTRA_ETL=root
# DB_PASSWORD_MANTRA_ETL=

# Mantra Datasources Database (optional)
# DB_HOST_MANTRA_DATASOURCES=127.0.0.1
# DB_PORT_MANTRA_DATASOURCES=3306
# DB_DATABASE_MANTRA_DATASOURCES=mantra_datasources
# DB_USERNAME_MANTRA_DATASOURCES=root
# DB_PASSWORD_MANTRA_DATASOURCES=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# IMPORTANT: CanvaStack requires cache driver that supports tagging
# Supported: database, redis, memcached
# NOT supported: array, file
CACHE_STORE=array
# CACHE_PREFIX=

# CanvaStack specific cache settings
CANVASTACK_CACHE_DRIVER=file
CANVASTACK_CACHE_ENABLED=true
TANSTACK_CSS_MODE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="dev@canvastack.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

