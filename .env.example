# CanvaStack Package Environment Configuration

# Application
APP_NAME="CanvaStack"
APP_ENV=local
APP_DEBUG=true

# Cache Configuration
CACHE_DRIVER=redis
CACHE_PREFIX=canvastack_cache

# CanvaStack Cache Settings
CANVASTACK_CACHE_ENABLED=true
CANVASTACK_CACHE_FORMS_TTL=3600
CANVASTACK_CACHE_TABLES_TTL=300
CANVASTACK_CACHE_PERMISSIONS_TTL=3600
CANVASTACK_CACHE_VIEWS_TTL=3600
CANVASTACK_CACHE_CONFIG_TTL=86400

# Queue Configuration
QUEUE_CONNECTION=redis

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3

# Database Configuration (for testing)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=canvastack_dev
DB_USERNAME=root
DB_PASSWORD=

# Performance Settings
CANVASTACK_CHUNK_SIZE=100
CANVASTACK_EAGER_LOAD=true
CANVASTACK_QUERY_CACHE=true

# Filter Configuration
# Enable bi-directional cascade globally (default: false)
CANVASTACK_BIDIRECTIONAL_CASCADE=false

# Debounce delay for filter changes in milliseconds (default: 300)
CANVASTACK_FILTER_DEBOUNCE=300

# Frontend cache TTL for filter options in seconds (default: 300)
CANVASTACK_FILTER_CACHE_TTL=300

# Maximum cascade depth to prevent infinite loops (default: 10)
CANVASTACK_MAX_CASCADE_DEPTH=10

# Show cascade indicators in UI (default: true)
CANVASTACK_SHOW_CASCADE_INDICATORS=true

# Filter optimization settings
CANVASTACK_FILTER_OPTIMIZATION=true
CANVASTACK_MAX_FILTER_OPTIONS=1000
CANVASTACK_FILTER_QUERY_TIMEOUT=30
CANVASTACK_FILTER_MEMORY_LIMIT=128M

# Filter cache settings
CANVASTACK_FILTER_CACHE_ENABLED=true
CANVASTACK_FILTER_CACHE_DRIVER=redis
CANVASTACK_FILTER_AUTO_INVALIDATE=true
CANVASTACK_FILTER_CACHE_WARMING=false

# Development Settings
CANVASTACK_DEBUG_QUERIES=true
CANVASTACK_LOG_SLOW_QUERIES=true
CANVASTACK_SLOW_QUERY_THRESHOLD=1000
