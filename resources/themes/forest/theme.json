  "typography": {
    "font_family": "Inter",
    "font_family_mono": "JetBrains Mono"
  },
  
  "dark_mode": {
    "enabled": true,
    "default": "light",
    "colors": {
      "primary": "#4ade80",
      "secondary": "#34d399",
      "accent": "#2dd4bf",
      "background": "#14532d",
      "surface": "#166534",
      "text": "#f0fdf4",
