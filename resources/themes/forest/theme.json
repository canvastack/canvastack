{
  "name": "forest",
  "display_name": "Forest",
  "version": "1.0.0",
  "author": "CanvaStack Team",
  "description": "A natural and calming theme inspired by forest greens",
  "preview_image": "preview.png",
  "tags": ["green", "nature", "forest", "calm", "eco"],
  
  "colors": {
    "primary": "#10b981",
    "secondary": "#059669",
    "accent": "#14b8a6",
    "success": "#22c55e",
    "warning": "#f59e0b",
    "error": "#ef4444",
    "info": "#3b82f6",
    "neutral": {
      "50": "#f0fdf4",
      "100": "#dcfce7",
      "200": "#bbf7d0",
      "300": "#86efac",
      "400": "#4ade80",
      "500": "#22c55e",
      "600": "#16a34a",
      "700": "#15803d",
      "800": "#166534",
      "900": "#14532d",
      "950": "#052e16"
    }
  },
  
  "gradients": {
    "primary": "linear-gradient(135deg, #10b981, #059669, #14b8a6)",
    "hero": "linear-gradient(to right, #10b981, #14b8a6)",
    "card": "linear-gradient(135deg, #f0fdf4, #d1fae5)",
    "button": "linear-gradient(to right, #10b981, #059669)"
