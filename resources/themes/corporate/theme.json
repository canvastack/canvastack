{
  "name": "corporate",
  "display_name": "Corporate",
  "version": "1.0.0",
  "author": "CanvaStack Team",
  "description": "A professional corporate theme with neutral colors and subtle accents",
  "preview_image": "preview.png",
  "tags": ["professional", "corporate", "neutral", "business", "minimal"],
  
  "colors": {
    "primary": "#2563eb",
    "secondary": "#475569",
    "accent": "#0ea5e9",
    "success": "#10b981",
    "warning": "#f59e0b",
    "error": "#ef4444",
    "info": "#3b82f6",
    "neutral": {
      "50": "#f8fafc",
      "100": "#f1f5f9",
      "200": "#e2e8f0",
      "300": "#cbd5e1",
      "400": "#94a3b8",
      "500": "#64748b",
      "600": "#475569",
      "700": "#334155",
      "800": "#1e293b",
      "900": "#0f172a",
      "950": "#020617"
    }
  },
  
  "gradients": {
    "primary": "linear-gradient(135deg, #2563eb, #1d4ed8)",
    "hero": "linear-gradient(to right, #1e40af, #1e3a8a)",
    "card": "linear-gradient(135deg, #f8fafc, #f1f5f9)",
    "button": "linear-gradient(to right, #2563eb, #1d4ed8)"
  },
  
  "typography": {
    "font_family": "Inter",
    "font_family_mono": "Roboto Mono"
  },
  
  "spacing": {
    "container_padding": "2rem",
    "section_spacing": "5rem"
  },
  
  "border_radius": {
    "sm": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem"
  },
  
  "dark_mode": {
    "enabled": true,
    "default": "light",
    "colors": {
      "primary": "#3b82f6",
      "secondary": "#64748b",
      "accent": "#0ea5e9",
      "background": "#0f172a",
      "surface": "#1e293b",
      "text": "#f1f5f9",
      "border": "#334155"
    }
  }
}
